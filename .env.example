# Copy this file to .env and add your own Gemini key.
# The backend auto-loads this file on startup (backend/app/config.py);
# real environment variables always take precedence over these values.
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
# Optional: override the default Gemini chat model.
GEMINI_MODEL=
# Optional: override the Gemini embedding model used for project RAG.
GEMINI_EMBEDDING_MODEL=
DATABASE_URL=sqlite:///./data/chats.db
# Optional: comma-separated CORS origins ("*" disables credentials).
# Defaults to http://localhost:3000,http://127.0.0.1:3000 when unset.
CORS_ALLOW_ORIGINS=
